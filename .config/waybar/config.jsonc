// -*- mode: jsonc -*-
{
    "height": 24, // Waybar height (to be removed for auto height)
    "layer": "top", // Waybar at top layer
    "margin-top": 0,
    "margin-left": 0,
    "margin-bottom": 0,
    "margin-right": 0,
    "spacing": 6, // Gaps between modules
    "reload_style_on_change": true,
    "include": "~/.config/waybar/cpu.jsonc",
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window",
        "mpris",
        "hyprland/submap"
    ],
    "modules-center": [
        // custom dynamic_island
        "clock"
    ],
    "modules-right": [
        "tray",

        "group/monitoring",

        // group control
        "group/control",

        "battery",

        // "custom/notification",
        // "custom/power-menu"
        "group/power"
    ],

    /*
        Groups
    */
    "group/monitoring": {
        "orientation": "inherit",
        "modules": [
            "custom/nvidia",
            "custom/amdgpu",
            "cpu",
            "temperature",
            "memory"
        ]
    },

    "group/control": {
        "orientation": "inherit",
        "modules": [
            "power-profiles-daemon",
            "idle_inhibitor",
            "backlight",
            "pulseaudio",
            "bluetooth",
            "network#wlan0",
            "network#enp3s0",
            "network#enp34s0"
        ]
    },

    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/power-menu", // First element is the "group leader" and won't ever be hidden
            "custom/divider",
            "custom/exit",
            "custom/lock"
        ]
    },

    /*
        Modules
    */
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "َ°² ",
            "2": "َ°²¢",
            "3": "َ°²¤",
            "4": "َ°²¦",
            "5": "َ°²¨",
            "6": "َ°²ھ",
            "7": "َ°²¬",
            "8": "َ°²®",
            "9": "َ°²°",
            "10": "َ°؟¬",
            "urgent": "ïپھ",
            "special": "َ°°¢",
            "default": "ï„‘"
        },
        "show-special": true,
        "special-visible-only": true
    },
    "hyprland/window": {
        "format": "CLASS:{class} _-_-_ {title}",
        "icon": true,
        "icon-size": 16,
        "separate-outputs": true,
        "max-length": 50,
        "rewrite": {
            "(.*)Mozilla Firefox": "Firefox",
            "(.*) - Chromium": "Chromium",
            "(.*) Microsoft Teams": "Teams",
            "(.*)Alacritty (.*)": "Alacritty",
            "CLASS:(.* _-_-_ )(.*)": "$2"
        }
    },
    "hyprland/submap": {
        "format": " َ°¥» {} "
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "interval": 1,
        "format": "{:%d %b - %H:%M}",
        "format-alt": "{:%Y-%m-%d - %H:%M:%S}",
        "tooltip-format": "{:%Y-%m-%d - %H:%M:%S}",
        "on-click-right": "killall rofi || ~/.local/bin/naivecalendar -t tokyonight -e 'alacritty -e nvim'"
    },

    "memory": {
        "interval": 5,
        "format": "î؟… {percentage:>2}%",
        "tooltip": true,
        "tooltip-format":"î؟… {used:0.2f}G/{total:0.2f}G\nï‘² {swapUsed:0.2f}G/{swapTotal:0.2f}G",
        "max-length": 10
    },
    "backlight": {
        // "device": "DP-1",
        "on-scroll-up": "brightnessctl s +5%",
        "on-scroll-down": "brightnessctl s 5%-",
        "format": "{icon}",
        "tooltip-format": "{icon} {percent}%",
        "format-icons": ["îژچ", "îڈ“", "îڈ‘", "îڈڈ", "îڈژ", "îڈچ", "îڈٹ", "îڈˆ", "îژ›"]
    },
    "network#wlan0": {
        "interface": "wlan0",
        "interval": 2,
        "format": "{icon}",
        "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
        "tooltip-format-wifi": "َ°–© {essid} {signalStrength}%\nَ°‡ڑ{bandwidthDownBytes:>4}  َ°•’{bandwidthUpBytes:>4}",
        "on-click": "bash ~/.config/waybar/scripts/rofi-wifi-menu.sh",
        "format-disconnected": "َ°¤­"
    },
    "network#enp3s0": {
        "interface": "enp3s0",
        "interval": 2,
        "format-ethernet": "َ°ˆ€",
        "tooltip-format-ethernet": "َ°ˆ€ {ipaddr}\nَ°‡ڑ{bandwidthDownBytes}  َ°•’{bandwidthUpBytes}",
        "format-disconnected": ""
    },
    "network#enp34s0": {
        "interface": "enp34s0",
        "interval": 2,
        "format-ethernet": "َ°ˆ€",
        "tooltip-format-ethernet": "َ°ˆ€ {ipaddr}\nَ°‡ڑ{bandwidthDownBytes}  َ°•’{bandwidthUpBytes}",
        "format-disconnected": ""
    },

    "pulseaudio": {
        "format": "{icon}",
        "tooltip-format": "{volume}% {icon} {source_desc}",
        "format-muted": "î»¨",
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï€¥",
            "headset": "َ°‹ژ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["ï€¦", "ï€§", "ï€¨"]
        },
        "scroll-step": 5.0,
        "on-click": "pavucontrol",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },

    "bluetooth": {
        "on-click": "bash ~/.config/waybar/scripts/rofi-bluetooth &",
        "format": "ïٹ”",
        "format-no-controller": "",
        "tooltip-format-connected-battery": "ïٹ” {device_alias} {device_battery_percentage}%",
        "format-on": "ïٹ”",
        "format-off": "َ°‚²"
    },

    "battery": {
      // "bat": "BAT0",
      // "adapter": "ADP0",
      "interval": 5,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "َ°‚„ {capacity}%",
      "format-plugged": "ï‡¦ {capacity}%",
      "format-alt": "{icon} {time}",
      "format-full": "{icon} {capacity}%",
      "format-icons": ["َ°پ؛", "َ°پ¼", "َ°پ¾", "َ°‚پ", "َ°پ¹"]
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ïƒ§",
            "performance": "ïƒ§",
            "balanced": "َ°—‘",
            "power-saver": "َ°Œھ"
        }
    },

    "custom/divider": {
        "format": "â”‚",
        "format-alt": "",
        "tooltip-format": ""
    },

    "custom/power-menu": {
        "format": "ï€‘",
        "tooltip-format": "Power Menu",
        "on-click": "killall rofi || bash ~/.config/waybar/scripts/power-menu/powermenu.sh"
    },
    "custom/lock": {
        "format": "ï‘–",
        "tooltip-format": "Lock",
        "on-click": "hyprlock"
    },
    "custom/exit": {
        "format": "َ°­‘",
        "tooltip-format": "Logout",
        "on-click": "hyprctl dispatch exit"
    },

    "mpris": {
        "format": "{player_icon} {title} - {artist}",
        "format-paused": "{player_icon} {status_icon} {title} - {artist}",
        "tooltip-format": "{player_icon} {player} - {status_icon} {status}\n{title} - {artist} - {album}\n{position}/{length}",
        "player-icons": {
            "default": "ïپ‹",
            "spotify": "ï†¼",
            "mpv": "َ°گ¹",
            "vlc": "َ°•¼",
            "firefox": "َ°ˆ¹",
            "plasma-browser-integration": "َ°ˆ¹",
            "chromium": "ï‰¨",
            "kdeconnect": "َ°„œ",
            "mopidy": "ï€پ"
        },
        "status-icons": {
            "paused": "ïپŒ",
            "playing": "ïپ‹",
            "stopped": "ïپچ"
        },
        "ignored-players": ["firefox", "chromium", "plasma-browser-integration", "kdeconnect"],
        "interval": 1,
        "ellipsis": "â€¦",
        "max-length": 40
    },
    "custom/launcher": {
        "format": "ïŒƒ",
        "tooltip-format": "Launcher",
        "on-click": "killall rofi || rofi -show drun -icon-theme breeze-dark"
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
            "none": "ï‚¢",
            "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-none": "ï‡·",
            "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
            "inhibited-none": "ï‚¢",
            "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-inhibited-none": "ï‡·"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ïپ®",
            "deactivated": "ïپ°"
        }
    },

    "custom/nvidia": {
        "exec-if": "which nvidia-smi >/dev/null",
        "exec": "~/.config/waybar/scripts/nvidiagpu-usage.sh",
        "format": "َ°¢® {icon} ", // useful at a glance, like the cpu module
        "format-alt": "َ°¢® {}% î؟… {alt}% ", // more detail, for when doing compute tasks
        "format-icons": [
            "<span color='#69ff94'>â–پ</span>", // green
            "<span color='#2aa9ff'>â–‚</span>", // blue
            "<span color='#f8f8f2'>â–ƒ</span>", // white
            "<span color='#f8f8f2'>â–„</span>", // white
            "<span color='#ffffa5'>â–…</span>", // yellow
            "<span color='#ffffa5'>â–†</span>", // yellow
            "<span color='#ff9977'>â–‡</span>", // orange
            "<span color='#dd532e'>â–ˆ</span>"  // red
        ],
        "return-type": "json",
        "interval": 2
    },

    "custom/amdgpu": {
        "exec-if": "cat /sys/class/drm/card1/device/gpu_busy_percent >/dev/null",
        "exec": "~/.config/waybar/scripts/amdgpu-usage.sh",
        "format": "َ°¢® {icon} ", // useful at a glance, like the cpu module
        "format-alt": "َ°¢® {}% î؟… {alt}% ", // more detail, for when doing compute tasks
        "format-icons": [
            "<span color='#69ff94'>â–پ</span>", // green
            "<span color='#2aa9ff'>â–‚</span>", // blue
            "<span color='#f8f8f2'>â–ƒ</span>", // white
            "<span color='#f8f8f2'>â–„</span>", // white
            "<span color='#ffffa5'>â–…</span>", // yellow
            "<span color='#ffffa5'>â–†</span>", // yellow
            "<span color='#ff9977'>â–‡</span>", // orange
            "<span color='#dd532e'>â–ˆ</span>"  // red
        ],
        "return-type": "json",
        "interval": 2
    }
}
